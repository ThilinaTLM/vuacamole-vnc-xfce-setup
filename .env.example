# Copy to .env and fill in. .env is gitignored.

# Password for the PostgreSQL role `guacamole_user` (must match the role you
# create in the system PostgreSQL — see PLAN.md Step 2).
POSTGRES_PASSWORD=change_me_use_a_long_random_value

# Public hostname (wildcard *.tlmtech.dev already resolves to this server).
GUAC_DOMAIN=desk.tlmtech.dev

# Email used by Caddy for Let's Encrypt / ACME registration.
ACME_EMAIL=you@tlmtech.dev
