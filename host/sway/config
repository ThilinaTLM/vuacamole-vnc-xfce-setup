# Minimal headless Sway config for the Guacamole/wayvnc remote desktop.
# Installed to ~/.config/sway/config by host/install-host.sh.
#
# Single source of truth for the wayvnc bind address/port is the `exec wayvnc`
# line at the bottom of this file. Do NOT also set address/port in
# ~/.config/wayvnc/config or precedence becomes ambiguous.

### Output -------------------------------------------------------------------
# The wlroots headless backend creates HEADLESS-1 (WLR_HEADLESS_OUTPUTS=1).
output HEADLESS-1 resolution 1920x1080 position 0 0
# Catppuccin Mocha wallpaper (needs the swaybg package). The installer replaces
# @WALLPAPER@ with the absolute path to the installed image. A static image is
# free over VNC after the first frame. Fallback if the file is missing:
#   output HEADLESS-1 bg #1e1e2e solid_color
output HEADLESS-1 bg @WALLPAPER@ fill

### XWayland (legacy X11 apps) ------------------------------------------------
xwayland enable

### Appearance ---------------------------------------------------------------
# Flat, crisp Catppuccin Mocha look. No SwayFX/blur/shadows/animations: the
# session is software-rendered (WLR_RENDERER=pixman, no GPU) and streamed over
# VNC, where animated pixels cost CPU + bandwidth. See docs/sway-wayvnc.md.
font pango:IosevkaTerm Nerd Font 11

gaps inner 8
gaps outer 4
smart_gaps on

default_border pixel 2
default_floating_border pixel 2
smart_borders on
titlebar_padding 8 4

# class                 border  bg      text    indicator child_border
client.focused          #cba6f7 #1e1e2e #cdd6f4 #cba6f7   #cba6f7
client.focused_inactive #313244 #181825 #a6adc8 #313244   #313244
client.unfocused        #313244 #181825 #6c7086 #313244   #313244
client.urgent           #f38ba8 #1e1e2e #1e1e2e #f38ba8   #f38ba8
client.placeholder      #313244 #181825 #cdd6f4 #313244   #313244
client.background       #1e1e2e

# Status bar (Waybar replaces Sway's built-in swaybar; see host/waybar/).
exec waybar

# Notification center (Catppuccin Mocha; see host/swaync/).
exec swaync

# App-grid "start menu" launched resident so the Waybar start button / $mod+d
# opens it instantly (see host/nwg-drawer/).
exec nwg-drawer -r

# Apply dark + reduced-motion appearance via gsettings (best-effort, idempotent).
# Surfaced to apps by xdg-desktop-portal-gtk → Firefox/Chromium go dark and
# report prefers-reduced-motion: reduce. See host/sway/apply-gsettings.sh.
exec_always ~/.config/sway/apply-gsettings.sh

### Modifier ------------------------------------------------------------------
# Use Alt as the Sway modifier so the more common Super/Win combos pass
# through to applications in the remote session.
set $mod Mod1

### Programs ------------------------------------------------------------------
set $term foot
# Start-menu app grid (nwg-drawer runs resident; this just toggles it visible).
set $menu nwg-drawer
# Lightweight quick-run fallback.
set $launcher fuzzel

### Key bindings --------------------------------------------------------------
bindsym $mod+Return exec $term
bindsym $mod+d exec $menu
bindsym $mod+Shift+d exec $launcher
bindsym $mod+q kill

# Notifications (swaync): toggle the panel / do-not-disturb.
bindsym $mod+n exec swaync-client -t -sw
bindsym $mod+Shift+n exec swaync-client -d -sw
bindsym $mod+Shift+c reload
bindsym $mod+Shift+e exec swaymsg exit

# Focus
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up
bindsym $mod+Right focus right

# Move
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up
bindsym $mod+Shift+Right move right

# Layout
bindsym $mod+f fullscreen
bindsym $mod+Shift+space floating toggle
bindsym $mod+space focus mode_toggle

# Workspaces
bindsym $mod+1 workspace number 1
bindsym $mod+2 workspace number 2
bindsym $mod+3 workspace number 3
bindsym $mod+4 workspace number 4
bindsym $mod+Shift+1 move container to workspace number 1
bindsym $mod+Shift+2 move container to workspace number 2
bindsym $mod+Shift+3 move container to workspace number 3
bindsym $mod+Shift+4 move container to workspace number 4

### Passthrough mode ----------------------------------------------------------
# Toggle a mode where Sway ignores nearly all bindings, so a browser/Guacamole
# user can send mod-key combinations straight into the remote applications.
# Enter with $mod+Shift+p, leave with the same combo or Escape.
mode "passthrough" {
    bindsym $mod+Shift+p mode "default"
    bindsym Escape mode "default"
}
bindsym $mod+Shift+p mode "passthrough"

### Remote access -------------------------------------------------------------
# Bind address/port live here only (single source of truth). The installer
# replaces @DOCKER_BRIDGE_GATEWAY@ with the detected docker0 gateway IP.
exec wayvnc @DOCKER_BRIDGE_GATEWAY@ 5901
